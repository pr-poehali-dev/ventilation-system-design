      "name": "Расчёт взрыва метана (газодинамика)",
      "method": "POST",
      "path": "/",
      "body": {
        "method": "gas_dynamics",
        "sourceType": "gas",
        "gasId": "methane",
        "gasVolume_m3": 100,
        "gasConcentration": 9.5,
        "excavationArea_m2": 20,
        "excavationLength_m": 100,
        "ambientPressure_kPa": 101.3,
        "considerWalls": true
