      "path": "/",
      "body": {
        "method": "fnip_494",
        "sourceType": "mass",
        "explosiveId": "ammonit",
        "explosiveMass_kg": 50,
        "excavationArea_m2": 15,
        "excavationLength_m": 50,
        "ambientPressure_kPa": 101.3,
        "considerWalls": true
      },
      "expectedStatus": 200,
      "expectedBody": {"q_tnt_kg": 48.5},
      "bodyMatcher": "partial"
    }
