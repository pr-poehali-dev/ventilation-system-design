{
  "tests": [
    {
      "name": "Пустая сеть",
      "method": "POST",
      "path": "/",
      "body": {"method": "cross", "nodes": [], "branches": [], "options": {}},
      "expectedStatus": 200,
      "expectedBody": {"converged": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Линейная цепь — метод Кросса",
      "method": "POST",
      "path": "/",
      "body": {
        "method": "cross",
        "nodes": [
          {"id": "U1", "isAtm": true},
          {"id": "N1"},
          {"id": "U2", "isAtm": true}
        ],
        "branches": [
          {"id": "B1", "fromId": "U1", "toId": "N1", "R": 0.1},
          {"id": "B2", "fromId": "N1", "toId": "U2", "R": 0.1, "hasFan": true, "fanMode": "constant", "fanPressure": 1000}
        ],
        "options": {"tolerance": 0.01, "maxIter": 1000}
      },
      "expectedStatus": 200,
      "expectedBody": {"converged": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "DEMO: линейная цепь 7 ветвей с вентилятором",
      "method": "POST",
      "path": "/",
      "body": {
        "method": "cross",
        "nodes": [
          {"id": "U1", "isAtm": true},
          {"id": "N1"}, {"id": "N2"}, {"id": "N3"},
          {"id": "N4"}, {"id": "N5"}, {"id": "N6"},
          {"id": "U2", "isAtm": true}
        ],
        "branches": [
          {"id": "B1", "fromId": "U1", "toId": "N1", "R": 0.01},
          {"id": "B2", "fromId": "N1", "toId": "N2", "R": 0.02},
          {"id": "B3", "fromId": "N2", "toId": "N3", "R": 0.05},
          {"id": "B4", "fromId": "N3", "toId": "N4", "R": 0.03},
          {"id": "B5", "fromId": "N4", "toId": "N5", "R": 0.08},
          {"id": "B6", "fromId": "N5", "toId": "N6", "R": 0.02},
          {"id": "B7", "fromId": "N6", "toId": "U2", "R": 0.01,
           "hasFan": true, "fanMode": "constant", "fanPressure": 2700}
        ],
        "options": {"tolerance": 0.001, "maxIter": 5000, "alpha": 0.8}
      },
      "expectedStatus": 200,
      "expectedBody": {"converged": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Тупик с ВМП — расход не нулевой",
      "method": "POST",
      "path": "/",
      "body": {
        "nodes": [
          {"id": "ATM", "isAtm": true},
          {"id": "J1"},
          {"id": "J2"},
          {"id": "DEAD"}
        ],
        "branches": [
          {"id": "MAIN", "fromId": "ATM", "toId": "J1", "R": 0.05, "hasFan": true, "fanMode": "constant", "fanPressure": 1500},
          {"id": "RING1", "fromId": "J1", "toId": "J2", "R": 0.1},
          {"id": "RING2", "fromId": "J2", "toId": "ATM", "R": 0.15},
          {"id": "VMP", "fromId": "J1", "toId": "DEAD", "R": 0.5, "hasFan": true, "fanMode": "constant", "fanPressure": 300, "area": 3.5}
        ],
        "options": {"tolerance": 0.001, "maxIter": 2000}
      },
      "expectedStatus": 200,
      "expectedBody": {"converged": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Шахтная сеть — 2 ствола + 5 выработок (как на схеме пользователя)",
      "method": "POST",
      "path": "/",
      "body": {
        "method": "cross",
        "nodes": [
          {"id": "ATM", "isAtm": true},
          {"id": "N1"}, {"id": "N2"}, {"id": "N3"},
          {"id": "N4"}, {"id": "N5"}
        ],
        "branches": [
          {"id": "svt",  "fromId": "ATM", "toId": "N1",  "R": 0.01, "hasFan": true, "fanMode": "constant", "fanPressure": 500},
          {"id": "kv",   "fromId": "N1",  "toId": "N2",  "R": 0.02},
          {"id": "ukl",  "fromId": "N2",  "toId": "N3",  "R": 0.03},
          {"id": "och",  "fromId": "N3",  "toId": "N4",  "R": 0.04},
          {"id": "sho",  "fromId": "N4",  "toId": "N5",  "R": 0.02},
          {"id": "shv",  "fromId": "N5",  "toId": "N2",  "R": 0.05},
          {"id": "yuvs", "fromId": "N1",  "toId": "ATM", "R": 0.01}
        ],
        "options": {"tolerance": 0.001, "maxIter": 5000, "alpha": 0.8}
      },
      "expectedStatus": 200,
      "expectedBody": {"converged": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "2 вентилятора в параллели — Q вдвое больше",
      "method": "POST",
      "path": "/",
      "body": {
        "method": "cross",
        "nodes": [
          {"id": "U1", "isAtm": true},
          {"id": "N1"},
          {"id": "U2", "isAtm": true}
        ],
        "branches": [
          {"id": "B1", "fromId": "U1", "toId": "N1", "R": 0.1},
          {"id": "B2", "fromId": "N1", "toId": "U2", "R": 0.1,
           "hasFan": true, "fanMode": "constant", "fanPressure": 1000, "fanParallel": 2}
        ],
        "options": {"tolerance": 0.01, "maxIter": 1000}
      },
      "expectedStatus": 200,
      "expectedBody": {"converged": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Реверс — Q всех ветвей должен быть отрицательным",
      "method": "POST",
      "path": "/",
      "body": {
        "nodes": [
          {"id": "U1", "isAtm": true},
          {"id": "N1"},
          {"id": "U2", "isAtm": true}
        ],
        "branches": [
          {"id": "B1", "fromId": "U1", "toId": "N1", "R": 0.1},
          {"id": "B2", "fromId": "N1", "toId": "U2", "R": 0.1,
           "hasFan": true, "fanMode": "constant", "fanPressure": 1000, "fanReverse": true}
        ],
        "options": {"tolerance": 0.01, "maxIter": 2000, "alpha": 0.8}
      },
      "expectedStatus": 200,
      "expectedBody": {"converged": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Остановка вентилятора — Q=0 во всей сети",
      "method": "POST",
      "path": "/",
      "body": {
        "nodes": [
          {"id": "U1", "isAtm": true},
          {"id": "N1"},
          {"id": "U2", "isAtm": true}
        ],
        "branches": [
          {"id": "B1", "fromId": "U1", "toId": "N1", "R": 0.1},
          {"id": "B2", "fromId": "N1", "toId": "U2", "R": 0.1,
           "hasFan": true, "fanMode": "constant", "fanPressure": 1000, "fanStopped": true}
        ],
        "options": {"tolerance": 0.01, "maxIter": 1000}
      },
      "expectedStatus": 200,
      "expectedBody": {"converged": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "3 ATM-узла — 2 ствола + 1 тупиковый ATM",
      "method": "POST",
      "path": "/",
      "body": {
        "nodes": [
          {"id": "ATM1", "isAtm": true},
          {"id": "ATM2", "isAtm": true},
          {"id": "ATM3", "isAtm": true},
          {"id": "J1"},
          {"id": "J2"}
        ],
        "branches": [
          {"id": "fan",   "fromId": "ATM1", "toId": "J1",  "R": 0.01, "hasFan": true, "fanMode": "constant", "fanPressure": 1000},
          {"id": "ring1", "fromId": "J1",   "toId": "J2",  "R": 0.1},
          {"id": "ring2", "fromId": "J2",   "toId": "ATM2","R": 0.1},
          {"id": "dead",  "fromId": "J1",   "toId": "ATM3","R": 0.1}
        ],
        "options": {"tolerance": 0.001, "maxIter": 3000}
      },
      "expectedStatus": 200,
      "expectedBody": {"converged": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Кольцевая сеть — 2 параллельных ветви, Кросс",
      "method": "POST",
      "path": "/",
      "body": {
        "method": "cross",
        "nodes": [
          {"id": "A", "isAtm": true},
          {"id": "B"},
          {"id": "C", "isAtm": true}
        ],
        "branches": [
          {"id": "fan", "fromId": "A", "toId": "B", "R": 0.01, "hasFan": true, "fanMode": "constant", "fanPressure": 500},
          {"id": "e1",  "fromId": "B", "toId": "C", "R": 0.1},
          {"id": "e2",  "fromId": "B", "toId": "C", "R": 0.2}
        ],
        "options": {"tolerance": 0.001, "maxIter": 5000, "alpha": 0.8}
      },
      "expectedStatus": 200,
      "expectedBody": {"converged": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Тупиковая цепочка 3 ветви — Q=0 во всех тупиках",
      "method": "POST",
      "path": "/",
      "body": {
        "nodes": [
          {"id": "ATM1", "isAtm": true},
          {"id": "ATM2", "isAtm": true},
          {"id": "J1"},
          {"id": "J2"},
          {"id": "D1"},
          {"id": "D2"},
          {"id": "D3"}
        ],
        "branches": [
          {"id": "main_fan", "fromId": "ATM1", "toId": "J1",  "R": 0.01, "hasFan": true, "fanMode": "constant", "fanPressure": 2000},
          {"id": "ring1",    "fromId": "J1",   "toId": "J2",  "R": 0.05},
          {"id": "ring2",    "fromId": "J2",   "toId": "ATM2","R": 0.05},
          {"id": "dead1",    "fromId": "J1",   "toId": "D1",  "R": 0.1},
          {"id": "dead2",    "fromId": "D1",   "toId": "D2",  "R": 0.1},
          {"id": "dead3",    "fromId": "D2",   "toId": "D3",  "R": 0.1}
        ],
        "options": {"tolerance": 0.001, "maxIter": 3000}
      },
      "expectedStatus": 200,
      "expectedBody": {"converged": true},
      "bodyMatcher": "partial"
    }
    ,
    {
      "name": "МКР — линейная цепь, сходимость",
      "method": "POST",
      "path": "/",
      "body": {
        "method": "mkr",
        "nodes": [
          {"id": "U1", "isAtm": true, "z": 0, "airTemp": 20},
          {"id": "N1", "z": -100, "airTemp": 15},
          {"id": "U2", "isAtm": true, "z": 0, "airTemp": 20}
        ],
        "branches": [
          {"id": "B1", "fromId": "U1", "toId": "N1", "R": 0.05},
          {"id": "B2", "fromId": "N1", "toId": "U2", "R": 0.05, "hasFan": true, "fanMode": "constant", "fanPressure": 1000}
        ],
        "options": {"tolerance": 0.01, "maxIter": 2000},
        "surfaceTemp": 20
      },
      "expectedStatus": 200,
      "expectedBody": {"converged": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "МКР — кольцевая сеть 2 параллельных ветви",
      "method": "POST",
      "path": "/",
      "body": {
        "method": "mkr",
        "nodes": [
          {"id": "A", "isAtm": true, "z": 0, "airTemp": 20},
          {"id": "B", "z": -50, "airTemp": 18},
          {"id": "C", "isAtm": true, "z": 0, "airTemp": 20}
        ],
        "branches": [
          {"id": "fan", "fromId": "A", "toId": "B", "R": 0.01, "hasFan": true, "fanMode": "constant", "fanPressure": 500},
          {"id": "e1",  "fromId": "B", "toId": "C", "R": 0.1},
          {"id": "e2",  "fromId": "B", "toId": "C", "R": 0.2}
        ],
        "options": {"tolerance": 0.01, "maxIter": 2000},
        "surfaceTemp": 20
      },
      "expectedStatus": 200,
      "expectedBody": {"converged": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "МКР — естественная тяга без вентилятора",
      "method": "POST",
      "path": "/",
      "body": {
        "method": "mkr",
        "nodes": [
          {"id": "U1", "isAtm": true, "z": 100, "airTemp": 5},
          {"id": "N1", "z": -200, "airTemp": 25},
          {"id": "U2", "isAtm": true, "z": 80, "airTemp": 5}
        ],
        "branches": [
          {"id": "B1", "fromId": "U1", "toId": "N1", "R": 0.05},
          {"id": "B2", "fromId": "N1", "toId": "U2", "R": 0.05}
        ],
        "options": {"tolerance": 0.01, "maxIter": 5000},
        "surfaceTemp": 5
      },
      "expectedStatus": 200,
      "expectedBody": {"nodes": []},
      "bodyMatcher": "partial"
    }
  ]
}