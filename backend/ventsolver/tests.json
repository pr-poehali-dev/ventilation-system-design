{
  "tests": [
    {
      "name": "Линейная сеть: 2 узла, 1 ветвь, вентилятор",
      "method": "POST",
      "path": "/",
      "body": {
        "nodes": [
          {"id": "U1", "atmosphereLink": true, "z": 0, "airTemp": 20},
          {"id": "U2", "atmosphereLink": true, "z": 0, "airTemp": 20}
        ],
        "branches": [
          {
            "id": "B1", "fromId": "U1", "toId": "U2",
            "resistance": 0.1,
            "area": 10, "perimeter": 12,
            "hasFan": true, "fanMode": "constant", "fanPressure": 1000
          }
        ],
        "options": {"maxIter": 50, "tolerance": 0.01}
      },
      "expectedStatus": 200,
      "expectedBody": {"ok": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Пустая сеть",
      "method": "POST",
      "path": "/",
      "body": {"nodes": [], "branches": [], "options": {}},
      "expectedStatus": 200,
      "expectedBody": {"ok": false},
      "bodyMatcher": "partial"
    }
  ]
}
