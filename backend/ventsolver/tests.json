{
  "tests": [
    {
      "name": "Последовательная цепь: вентилятор 1000 Па, R=0.1 каждая",
      "method": "POST",
      "path": "/",
      "body": {
        "nodes": [
          {"id": "A", "atmosphereLink": true,  "z": 0, "airTemp": 20},
          {"id": "B", "atmosphereLink": false, "z": 0, "airTemp": 20},
          {"id": "C", "atmosphereLink": true,  "z": 0, "airTemp": 20}
        ],
        "branches": [
          {
            "id": "e1", "fromId": "A", "toId": "B",
            "resistance": 0.1, "area": 10, "perimeter": 14,
            "hasFan": true, "fanMode": "constant", "fanPressure": 1000
          },
          {
            "id": "e2", "fromId": "B", "toId": "C",
            "resistance": 0.1, "area": 10, "perimeter": 14,
            "hasFan": false, "fanMode": "constant", "fanPressure": 0
          }
        ],
        "options": {"maxIter": 2000, "tolerance": 0.001, "tolPressure": 0.01}
      },
      "expectedStatus": 200,
      "expectedBody": {"ok": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Параллельные ветви: 1 вентилятор, кольцо",
      "method": "POST",
      "path": "/",
      "body": {
        "nodes": [
          {"id": "A", "atmosphereLink": true,  "z": 0, "airTemp": 20},
          {"id": "B", "atmosphereLink": false, "z": 0, "airTemp": 20},
          {"id": "C", "atmosphereLink": false, "z": 0, "airTemp": 20},
          {"id": "D", "atmosphereLink": true,  "z": 0, "airTemp": 20}
        ],
        "branches": [
          {
            "id": "fan", "fromId": "A", "toId": "B",
            "resistance": 0.05, "area": 38.5, "perimeter": 25,
            "hasFan": true, "fanMode": "constant", "fanPressure": 500
          },
          {
            "id": "p1", "fromId": "B", "toId": "C",
            "resistance": 0.2, "area": 20, "perimeter": 18,
            "hasFan": false, "fanMode": "constant", "fanPressure": 0
          },
          {
            "id": "p2", "fromId": "B", "toId": "D",
            "resistance": 0.1, "area": 15, "perimeter": 16,
            "hasFan": false, "fanMode": "constant", "fanPressure": 0
          },
          {
            "id": "p3", "fromId": "C", "toId": "D",
            "resistance": 0.15, "area": 18, "perimeter": 17,
            "hasFan": false, "fanMode": "constant", "fanPressure": 0
          }
        ],
        "options": {"maxIter": 2000, "tolerance": 0.001, "tolPressure": 0.01}
      },
      "expectedStatus": 200,
      "expectedBody": {"ok": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Пустая сеть",
      "method": "POST",
      "path": "/",
      "body": {"nodes": [], "branches": [], "options": {}},
      "expectedStatus": 200,
      "expectedBody": {"ok": false},
      "bodyMatcher": "partial"
    }
  ]
}
