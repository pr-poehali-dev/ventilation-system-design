{
  "tests": [
    {
      "name": "Check unknown fingerprint returns not licensed",
      "method": "POST",
      "path": "/",
      "body": {"action": "check", "fingerprint": "test-unknown-fp-xyz-999", "hostname": "Chrome / Windows 10", "platform": "Windows 10", "screen_info": "1920x1080"},
      "expectedStatus": 200,
      "expectedBody": {"licensed": false},
      "bodyMatcher": "partial"
    },
    {
      "name": "Activate with invalid key format",
      "method": "POST",
      "path": "/",
      "body": {"action": "activate", "fingerprint": "test-fp-abc-123", "key": "BADKEY", "hostname": "Chrome / Windows 10"},
      "expectedStatus": 400,
      "expectedBody": {"error": "invalid_key_format"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Activate with non-existent valid-format key",
      "method": "POST",
      "path": "/",
      "body": {"action": "activate", "fingerprint": "test-fp-abc-123", "key": "PVS-0000-0000-0000-0000", "platform": "Windows 10", "screen_info": "1920x1080"},
      "expectedStatus": 404,
      "expectedBody": {"error": "key_not_found"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Transfer with invalid key format",
      "method": "POST",
      "path": "/",
      "body": {"action": "transfer", "fingerprint": "old-fp", "new_fingerprint": "new-fp", "key": "BADKEY"},
      "expectedStatus": 400,
      "expectedBody": {"error": "invalid_key_format"},
      "bodyMatcher": "partial"
    }
  ]
}
