{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PV-Sistema",
  "version": "1.0.0",
  "identifier": "ru.pvs.desktop",
  "build": {
    "frontendDist": "../../dist-desktop",
    "devUrl": "http://localhost:5174",
    "beforeDevCommand": "bun run dev:desktop",
    "beforeBuildCommand": "bun run build:desktop"
  },
  "app": {
    "windows": [
      {
        "title": "PV-Sistema",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "binaries/python-server.exe"
    ],
    "nsis": {
      "languages": ["Russian"],
      "displayLanguageSelector": false,
      "installMode": "currentUser"
    }
  }
}