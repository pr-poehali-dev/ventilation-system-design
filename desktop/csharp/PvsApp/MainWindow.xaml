<Window x:Class="PvsApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="ПВ-Система"
        Width="1400" Height="900"
        MinWidth="1024" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Icon="pvs.ico">

  <Grid>
    <!-- Splash / загрузка -->
    <Grid x:Name="SplashGrid" Background="#1e293b" Panel.ZIndex="10">
      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
        <TextBlock Text="ПВ-Система"
                   Foreground="White" FontSize="32" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,12"/>
        <TextBlock Text="Запуск расчётного ядра..."
                   x:Name="SplashStatus"
                   Foreground="#94a3b8" FontSize="14"
                   HorizontalAlignment="Center" Margin="0,0,0,24"/>
        <ProgressBar x:Name="SplashProgress" IsIndeterminate="True"
                     Width="280" Height="4"
                     Background="#334155" Foreground="#3b82f6"/>
      </StackPanel>
    </Grid>

    <!-- WebView2 -->
    <wv2:WebView2 x:Name="WebView"
                  Visibility="Collapsed"/>
  </Grid>
</Window>
